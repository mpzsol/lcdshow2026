#!/bin/bash
set -e

echo "[+] lcdshow2026 — Modern LCD installer (2026 Edition)"
echo "[+] Auto-detecting environment..."

# ---------------------------------------------------------
# 1. Detect boot config path
# ---------------------------------------------------------
if [ -d /boot/firmware ]; then
    BOOTCFG="/boot/firmware/config.txt"
else
    BOOTCFG="/boot/config.txt"
fi
echo "[+] Using config file: $BOOTCFG"

# ---------------------------------------------------------
# 2. Detect kernel major version
# ---------------------------------------------------------
KVER=$(uname -r | cut -d. -f1)
echo "[+] Kernel major version: $KVER"

if [ "$KVER" -ge 6 ]; then
    echo "[+] Kernel uses full KMS — disabling for SPI LCD"
    DISABLE_KMS=1
else
    DISABLE_KMS=0
fi

# ---------------------------------------------------------
# 3. Detect LCD controller
# ---------------------------------------------------------
LCD_CHIP="unknown"

if dmesg | grep -qi "ili9486"; then
    LCD_CHIP="ili9486"
elif dmesg | grep -qi "ili9341"; then
    LCD_CHIP="ili9341"
elif dmesg | grep -qi "hx8357"; then
    LCD_CHIP="hx8357d"
elif dmesg | grep -qi "st7789"; then
    LCD_CHIP="st7789"
fi

echo "[+] Detected LCD controller: $LCD_CHIP"

# ---------------------------------------------------------
# 4. Manual LCD override (2nd argument)
# ---------------------------------------------------------
if [[ -n "$2" ]]; then
    echo "[+] Manual LCD override: $2"
    LCD_CHIP="$2"
fi

# ---------------------------------------------------------
# 5. Detect touchscreen controller
# ---------------------------------------------------------
TOUCH_CHIP="none"

if dmesg | grep -qi "ads7846"; then
    TOUCH_CHIP="ads7846"
elif dmesg | grep -qi "xpt2046"; then
    TOUCH_CHIP="xpt2046"
fi

echo "[+] Detected touchscreen: $TOUCH_CHIP"

# ---------------------------------------------------------
# 6. Manual touchscreen override (3rd argument)
# ---------------------------------------------------------
if [[ -n "$3" ]]; then
    echo "[+] Manual touchscreen override: $3"
    TOUCH_CHIP="$3"
fi

# ---------------------------------------------------------
# 7. Rotation support
# ---------------------------------------------------------
ROTATION="$1"

case "$ROTATION" in
    0|90|180|270)
        echo "[+] Applying rotation: $ROTATION degrees"
        ROTATE_PARAM=",rotate=${ROTATION}"
        ;;
    "")
        echo "[+] No rotation specified — checking auto-rotation..."
        if dmesg | grep -qi "portrait"; then
            ROTATE_PARAM=",rotate=90"
            echo "[+] Auto-rotation: 90 degrees"
        else
            ROTATE_PARAM=""
            echo "[+] Default rotation: 0 degrees"
        fi
        ;;
    *)
        echo "[!] Invalid rotation. Use: 0, 90, 180, or 270"
        exit 1
        ;;
esac

# ---------------------------------------------------------
# 8. Enable SPI
# ---------------------------------------------------------
echo "[+] Enabling SPI..."
sudo raspi-config nonint do_spi 0

# ---------------------------------------------------------
# 9. Select overlay
# ---------------------------------------------------------
sudo mkdir -p /boot/overlays

case "$LCD_CHIP" in
